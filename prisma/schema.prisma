generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  MANAGER
}

enum EventType {
  PLUS
  MINUS
}

enum EventStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  ARCHIVED
}

enum ActionStatus {
  SUGGESTED
  APPROVED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum ContextType {
  PERMANENT
  CONDITIONAL
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(MANAGER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages           Message[]
  events             Event[]                  @relation("assignedEvents")
  categoryAccess     UserCategoryAccess[]
  emailAccountAccess UserEmailAccountAccess[]
  pageAccess         UserPageAccess[]
}

model Event {
  id         String      @id @default(cuid())
  title      String
  summary    String?     @db.Text
  rawContent String?     @db.Text
  source     String?
  type       EventType
  status     EventStatus @default(NEW)
  priority   Int         @default(0)
  categoryId     String?
  assignedTo     String?
  emailAccountId String?
  senderEmail    String?
  senderName     String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  resolvedAt     DateTime?
  updatedAt      DateTime    @updatedAt

  category     EventCategory? @relation(fields: [categoryId], references: [id])
  assignee     User?          @relation("assignedEvents", fields: [assignedTo], references: [id])
  emailAccount EmailAccount?  @relation(fields: [emailAccountId], references: [id], onDelete: SetNull)
  actions      EventAction[]
  messages     Message[]

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([emailAccountId])
}

model EventCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  contextMd   String? @db.Text
  color       String?

  events     Event[]
  userAccess UserCategoryAccess[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EmailAccount {
  id           String  @id @default(cuid())
  label        String
  email        String  @unique
  imapHost     String
  imapPort     Int     @default(993)
  imapUser     String
  imapPassword String
  imapTls      Boolean @default(true)
  smtpHost     String?
  smtpPort     Int?    @default(587)
  smtpUser     String?
  smtpPassword String?
  smtpTls      Boolean @default(true)
  enabled      Boolean @default(true)
  lastPolledAt DateTime?
  lastError    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events     Event[]
  userAccess UserEmailAccountAccess[]
}

model UserCategoryAccess {
  id         String @id @default(cuid())
  userId     String
  categoryId String

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category EventCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([userId])
}

model UserEmailAccountAccess {
  id             String @id @default(cuid())
  userId         String
  emailAccountId String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAccount EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, emailAccountId])
  @@index([userId])
}

model EventAction {
  id          String       @id @default(cuid())
  eventId     String
  title       String
  description String?      @db.Text
  status      ActionStatus @default(SUGGESTED)
  aiSuggested Boolean      @default(true)
  result      String?      @db.Text
  createdAt   DateTime     @default(now())
  executedAt  DateTime?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Message {
  id           String   @id @default(cuid())
  content      String   @db.Text
  role         String
  eventId      String?
  customPageId String?
  threadId     String?
  userId       String?
  metadata     Json?
  createdAt    DateTime @default(now())

  event      Event?      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  customPage CustomPage? @relation(fields: [customPageId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([customPageId])
  @@index([threadId])
  @@index([createdAt(sort: Desc)])
}

model AgentContext {
  id        String      @id @default(cuid())
  name      String
  type      ContextType
  content   String      @db.Text
  enabled   Boolean     @default(true)
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model CompanyInfo {
  id      String @id @default("default")
  name    String @default("")
  ico     String @default("")
  dic     String @default("")
  icDph   String @default("")
  address String @default("")
  email   String @default("")
  phone   String @default("")
  web     String @default("")
  extra   Json?
}

model SectionCategory {
  id    String @id @default(cuid())
  name  String
  order Int    @default(0)

  pages CustomPage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomPage {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  icon       String?
  config     Json     @default("{}")
  code       String?  @db.Text
  published  Boolean  @default(false)
  order      Int      @default(0)
  categoryId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category   SectionCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  userAccess UserPageAccess[]
  messages   Message[]
  snapshots  Snapshot[]

  @@index([categoryId])
}

model UserPageAccess {
  id     String @id @default(cuid())
  userId String
  pageId String

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  page CustomPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([userId, pageId])
  @@index([userId])
}

model Snapshot {
  id           String   @id @default(cuid())
  label        String
  parentId     String?
  customPageId String?

  codeState    Json
  schemaDdl    String   @db.Text
  dataFile     String?
  dataHash     String?
  dataSize     Int      @default(0)

  isCurrent    Boolean  @default(false)

  createdAt    DateTime @default(now())

  parent       Snapshot?  @relation("SnapshotTree", fields: [parentId], references: [id])
  children     Snapshot[] @relation("SnapshotTree")
  customPage   CustomPage? @relation(fields: [customPageId], references: [id], onDelete: SetNull)

  @@index([isCurrent])
  @@index([createdAt(sort: Desc)])
  @@index([dataHash])
  @@index([customPageId])
}

model CronJob {
  id        String    @id @default(cuid())
  name      String
  schedule  String
  action    String    @db.Text
  enabled   Boolean   @default(false)
  lastRun   DateTime?
  nextRun   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
